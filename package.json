{
  "name": "hack-agent",
  "version": "0.1.0",
  "description": "Autonomous hackathon agent runtime",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "files": [
    "dist/"
  ],
  "bin": {
      "hackagent": "dist/cli/index.js",
      "hag": "dist/cli/index.js"
    },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "hackagent": "tsx cli/index.ts",
    "hag": "tsx cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint benchmarks/ tests/ cli/ kernel/",
    "lint:fix": "eslint benchmarks/ tests/ cli/ kernel/ --fix",
    "format": "prettier --write \"benchmarks/**/*.ts\" \"tests/**/*.ts\" \"cli/**/*.ts\" \"kernel/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "xstate": "^5.19.2",
    "zod": "^3.24.2",
    "uuid": "^11.1.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
