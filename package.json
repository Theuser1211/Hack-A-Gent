{
  "name": "hag-cli",
  "version": "1.0.4",
  "description": "Autonomous hackathon engineering CLI — generate complete projects from Devpost URLs",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "hackathon",
    "devpost",
    "automation",
    "typescript"
  ],
  "author": "Hack-A-Gent Contributors",
  "license": "MIT",
  "homepage": "https://github.com/Theuser1211/Hack-A-Gent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Theuser1211/Hack-A-Gent.git"
  },
  "bugs": {
    "url": "https://github.com/Theuser1211/Hack-A-Gent/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "types": "dist/cli/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "hackagent": "dist/cli/index.js",
    "hag": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build && node --eval \"import{rmSync,readdirSync,existsSync}from'fs';import{join}from'path';if(existsSync('dist/tests'))rmSync('dist/tests',{recursive:true});function rmFiles(dir){if(!existsSync(dir))return;for(const e of readdirSync(dir,{withFileTypes:true})){const p=join(dir,e.name);if(e.isDirectory())rmFiles(p);else if(e.name.endsWith('.d.ts')||e.name.endsWith('.d.ts.map')||e.name.endsWith('.js.map')||e.name.endsWith('.map'))rmSync(p);}}rmFiles('dist');\"",
    "dev": "tsx watch cli/index.ts",
    "hackagent": "tsx cli/index.ts",
    "hag": "tsx cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint benchmarks/ tests/ cli/ kernel/",
    "lint:fix": "eslint benchmarks/ tests/ cli/ kernel/ --fix",
    "format": "prettier --write \"benchmarks/**/*.ts\" \"tests/**/*.ts\" \"cli/**/*.ts\" \"kernel/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "xstate": "^5.19.2",
    "zod": "^3.24.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
